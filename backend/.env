# ==============================================================================
# THE LOGGER — BACKEND ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- Database Connection ---
# Default uses SQLite:
DATABASE_URL=sqlite:///data/logger.db

# To migrate to PostgreSQL, uncomment and customize the line below:
DATABASE_URL=postgresql://avnadmin:AVNS_daV26yDr6fhaoJtZfV7@pg-3cb276e8-vigneshpandian0710-d758.g.aivencloud.com:22338/logger_db?sslmode=require

# --- CORS Settings ---
# Comma-separated list of allowed origins (or "*" to allow all)
CORS_ORIGINS=*

# --- Server Host & Port ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Legacy Desktop App Decryption Keys ---
# Used to seed migrations from users.json, email_settings.json, and devices.json
LEGACY_AUTH_DECRYPT_KEY=5DD8180B9BC94632
LEGACY_DEVICE_DECRYPT_KEY=0E441257DCFDB6C2

# --- Default Admin Account ---
# Created during self-healing database seeding if no users exist
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# --- Modbus Connection Overrides ---
# Override host/port globally for all Modbus TCP connections (leave empty to use DB settings)
MODBUS_OVERRIDE_HOST=
MODBUS_OVERRIDE_PORT=

# --- JWT Authentication Settings ---
